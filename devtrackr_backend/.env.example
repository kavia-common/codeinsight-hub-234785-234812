# DevTrackr Backend env vars (example)
# Do not commit real secrets.

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000

# Database (provided by orchestrator; names must match database container db_env_vars)
POSTGRES_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Auth/session
JWT_SECRET=
JWT_ISSUER=devtrackr
JWT_AUDIENCE=devtrackr-web
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

# Cookies
# For cross-origin frontend<->backend with credentials:
# - Use COOKIE_SECURE=true (required by browsers when SameSite=None)
# - Use COOKIE_SAMESITE=none to allow third-party/cross-site cookies (common in preview URLs)
# - Optionally set COOKIE_DOMAIN to share cookies across subdomains (leave blank for localhost)
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# OAuth
SITE_URL=http://localhost:3000

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# AI provider abstraction (placeholder)
AI_PROVIDER=stub
AI_MODEL=stub

# Webhook verification (optional - repo specific secrets are stored per repo)
DEFAULT_WEBHOOK_SECRET=
